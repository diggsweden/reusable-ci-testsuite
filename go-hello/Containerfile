# Container-first fixture for go-hello. Mirrors the structure of
# examples/go-service/Containerfile.example. Three stages: builder,
# export-binary (scratch), runtime (distroless).
#
# No -X main.date=... ldflag — exercising the documented "preferred"
# pattern (binary reproducibility via the Go-team-blessed
# -trimpath -buildvcs=false without needing SOURCE_DATE_EPOCH to
# flow into the build sandbox).

# syntax=docker/dockerfile:1.7

FROM --platform=$BUILDPLATFORM golang:1.26-bookworm AS builder

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .

ARG TARGETOS
ARG TARGETARCH
ARG VERSION=dev

RUN CGO_ENABLED=0 GOOS=$TARGETOS GOARCH=$TARGETARCH \
    go build \
      -trimpath \
      -buildvcs=false \
      -ldflags="-s -w -X main.version=${VERSION}" \
      -o /out/go-hello ./

FROM scratch AS export-binary
COPY --from=builder /out/go-hello /go-hello

FROM gcr.io/distroless/static-debian12:nonroot AS runtime
COPY --from=builder /out/go-hello /usr/local/bin/go-hello
ENTRYPOINT ["/usr/local/bin/go-hello"]
